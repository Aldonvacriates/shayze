# --- Dependencies & build output ---
node_modules
dist
dist-ssr
.vite
*.tsbuildinfo

# --- Environment & secrets ---
# Never commit env files — they often contain API keys, DB URLs, etc.
.env
.env.*
!.env.example

# Signing keys for Android / iOS — committing these means anyone can publish
# fraudulent updates of your app. Keep them out of the repo, always.
*.jks
*.keystore
*.p12
*.mobileprovision
*.cer
keystore.properties
google-services.json
GoogleService-Info.plist

# --- Hosting / deployment ---
.vercel
.netlify

# --- Logs & temp ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.cache

# --- IDE / editor ---
.vscode
.idea
*.swp
*.swo

# --- OS junk ---
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# --- Design source (private) ---
# The Figma Make file is the proprietary design source — keep it local only.
*.make

# --- Capacitor / native ---
# iOS Pods are platform-specific build artifacts; the Podfile.lock stays
ios/App/Pods
ios/App/build
ios/DerivedData
